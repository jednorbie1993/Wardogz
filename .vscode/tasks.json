{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run C Program",
      "type": "shell",
      "command": "gcc",
      "args": [
        "${file}",
        "-o",
        "${workspaceFolder}/output/${fileBasenameNoExtension}.exe",
        "&&",
        "${workspaceFolder}/output/${fileBasenameNoExtension}.exe"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}